---
export interface Props {
	title: string
	placeName: string
	address: string
	date: string
	time: string
	locationUrl: string
}
const { title, placeName, address, date, time, locationUrl } = Astro.props
---

<>
	<div class="grid grid-cols-1">
		<div
			data-animate="fade-down"
			class="mb-6 flex items-center gap-4"
		>
			<div class="h-px w-full animate-line" style="background: linear-gradient(to right, transparent, #c8956c40);"></div>
			<p class="text-4xl satisfy shrink-0 max-w-[60%] overflow-visible" style="color: #f5e6d3;">
				<span class="overflow-visible">{title}</span>
			</p>
			<div class="h-px w-full animate-line" style="background: linear-gradient(to left, transparent, #c8956c40);"></div>
		</div>
		<p class="mb-1 font-bold text-lg" data-animate="fade-up" data-animate-delay="100" style="color: #e8d5b7;">
			{placeName}
		</p>
		<p class="mb-1" data-animate="fade-up" data-animate-delay="150" style="color: #b0a8b8;">
			<iconify-icon icon="mdi:calendar-blank" width="18" height="18" style="color: #c8956c;"></iconify-icon>
			{date}
		</p>
		<p class="mb-1" data-animate="fade-up" data-animate-delay="200" style="color: #b0a8b8;">
			<iconify-icon icon="mdi:clock-outline" width="18" height="18" style="color: #c8956c;"></iconify-icon>
			{time}
		</p>

		<p
			class="text-sm mb-1 overflow-visible"
			data-animate="fade-up"
			data-animate-delay="250"
			style="color: #8a8494;"
		>
			<iconify-icon icon="mdi:map-marker-outline" width="18" height="18" style="color: #c8956c;"></iconify-icon>
			<span class="overflow-visible">{address}</span>
		</p>
		<div class="mt-6" data-animate="zoom-in" data-animate-delay="350">
			<a
				href={locationUrl}
				type="button"
				class="animate-hover inline-block transition-all duration-300 outline-none h-10 px-6 text-sm rounded-full"
				style="color: #f5e6d3; border: 1px solid #c8956c50; background: rgba(200,149,108,0.08);"
				target="_blank"
				><span
					class="flex items-center h-full w-full justify-center gap-1 flex-nowrap whitespace-nowrap"
				>
					<iconify-icon icon="mdi:map" width="18" height="18" style="color: #c8956c;"></iconify-icon>
					 Open Map</span
				></a
			>
		</div>
	</div>
</>
