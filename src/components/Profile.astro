---
export interface Props {
	name: string
	birthOrder: string
	parents: string
}
const { name, birthOrder, parents } = Astro.props

---

<>
	<div
		data-animate="fade-up"
		data-animate-delay="300"
		class="w-full text-center relative flex flex-col justify-center"
	>
		<p class="text-2xl font-bold mb-2 overflow-visible" style="color: #f5e6d3;">
			<span class="overflow-visible">{name}</span>
		</p><p class="text-md font-bold mb-1 overflow-visible" style="color: #c8956c;">
			<span class="overflow-visible">{birthOrder}</span>
		</p><p class="text-md font-light overflow-visible" style="color: #b0a8b8;">
			<span class="overflow-visible">{parents}</span>
		</p>
	</div>
</>
