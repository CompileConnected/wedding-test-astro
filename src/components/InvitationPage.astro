---
import OpenInvitationButton from '../components/OpenInvitationButton.svelte'
import cover from '../assets/cover.avif'
---


<div class="h-screen bg-slate-900" data-animate="fade-in">
    <div class="absolute inset-0">
        <img
            src={cover.src}
            loading="lazy"
            decoding="async"
            class="w-full h-full object-cover mx-auto max-w-screen-md md:max-w-screen-sm transition-all grayscale-0 scale-100"
        />
    </div>

    <div class="relative flex flex-col flex-wrap justify-end h-screen text-white">
        <div class="flex flex-col items-center content-center py-8">
            <div class="satisfy text-center text-5xl font-bold" data-animate="fade-up" data-animate-delay="300">Yohanes & Citra</div>
            <div class="text-center mx-8 p-3" data-animate="fade-up" data-animate-delay="600">
                <p class="text-xs">Dear, </p>
                <h5 id="guest-name" class="text-base font-bold overflow-visible"></h5>
            </div>
            <div data-animate="zoom-in" data-animate-delay="900">
                <OpenInvitationButton client:load />
            </div>
        </div>
    </div>
</div>

<script>
    const name = new URLSearchParams(window.location.search).get('to')
    const el = document.getElementById('guest-name')
    if (el && name) el.textContent = name
</script>